# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_name

# Channel subscription check (set to your channel username without @)
CHANNEL_USERNAME=your_channel_name

# Database (Vercel will auto-inject these)
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# KV Store (Vercel will auto-inject these)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# App URL (your Vercel deployment URL)
APP_URL=https://your-app.vercel.app